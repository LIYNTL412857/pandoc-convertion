{
  "name": "pandoc-converter-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.example.pandoc-converter",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "./pandoc/",
        "to": "pandoc",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "child_process": "^1.0.2",
    "fs-extra": "^11.3.4",
    "path": "^0.12.7",
    "temp": "^0.9.4"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
